APP_NAME="WA Queue"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://wa-queue.test

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── SQLite (خفيف — بدون MySQL) ──────────────────────────
DB_CONNECTION=sqlite

# ── Session / Cache / Queue ───────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=database

# ── TextMeBot ─────────────────────────────────────────────
TEXTMEBOT_SEND_URL=https://api.textmebot.com/send.php
TEXTMEBOT_STATUS_URL=https://api.textmebot.com/status.php

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
